# =============================================================================
# MeetSpace — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Server port
PORT=5001

# Environment: production | development
NODE_ENV=production

# Your domain (used for CORS)
CLIENT_URL=https://meetconnect.swiftcampus.com

# ── mediasoup ─────────────────────────────────────────────────────────────────
# MUST be your VPS public IP address (not 0.0.0.0 or localhost)
MEDIASOUP_ANNOUNCED_IP=YOUR_VPS_PUBLIC_IP

# UDP port range for WebRTC media (open these in firewall)
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# ── coturn TURN server ────────────────────────────────────────────────────────
# Your VPS public IP
TURN_HOST=YOUR_VPS_PUBLIC_IP

# TURN UDP/TCP port (open in firewall)
TURN_PORT=3478

# TURNS TLS port (open in firewall)
TURN_TLS_PORT=5349

# Random secret — generate with: openssl rand -hex 32
TURN_SECRET=your_random_64_char_secret_here

# Credential TTL in seconds (86400 = 24 hours)
TURN_TTL=86400

# Your domain
TURN_REALM=meetconnect.swiftcampus.com
