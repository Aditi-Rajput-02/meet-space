# ─────────────────────────────────────────────────────────────────────────────
# MeetSpace — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# Your domain (used for CORS)
CLIENT_URL=https://meetconnect.swiftcampus.com

# ── mediasoup ─────────────────────────────────────────────────────────────────
# MUST be your server's PUBLIC IP address (not 127.0.0.1, not localhost)
# Get it with: curl ifconfig.me  (Linux) or  curl https://api.ipify.org  (Windows)
MEDIASOUP_ANNOUNCED_IP=YOUR_SERVER_PUBLIC_IP

# UDP port range for WebRTC media (must match docker-compose port mapping)
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# ── coturn TURN Server ────────────────────────────────────────────────────────
TURN_HOST=YOUR_SERVER_PUBLIC_IP
TURN_PORT=3478
TURN_TLS_PORT=5349

# Generate a strong random secret:
#   Linux:   openssl rand -hex 32
#   Windows: powershell -Command "[System.Web.Security.Membership]::GeneratePassword(32,0)"
#   Or use:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TURN_SECRET=YOUR_STRONG_RANDOM_SECRET_HERE

TURN_TTL=86400
TURN_REALM=meetconnect.swiftcampus.com
