#!/bin/bash
# .plesk-deploy — Plesk Git post-deployment script
# This runs automatically after every git pull in Plesk
# Configure in Plesk: Git → Deployment → Additional deploy actions

set -e  # Exit on any error

echo "🚀 MeetSpace Post-Deployment Script Starting..."
echo "   Directory: $(pwd)"
echo "   Node: $(node --version)"
echo "   NPM: $(npm --version)"

# ─── Step 1: Install frontend dependencies ────────────────────────────────────
echo ""
echo "📦 Step 1: Installing frontend dependencies..."
cd frontend
npm install
echo "✅ Frontend dependencies installed"

# ─── Step 2: Build frontend ───────────────────────────────────────────────────
echo ""
echo "🔨 Step 2: Building frontend for production..."

# Create frontend/.env if it doesn't exist
if [ ! -f ".env" ]; then
  echo "VITE_SOCKET_URL=https://meetspace.swiftcampus.com" > .env
  echo "✅ Created frontend/.env"
fi

npm run build
echo "✅ Frontend built → frontend/dist/"

# ─── Step 3: Install backend (root) dependencies ─────────────────────────────
echo ""
echo "📦 Step 3: Installing backend dependencies..."
cd ..
npm install --omit=dev
echo "✅ Backend dependencies installed"

# ─── Done ─────────────────────────────────────────────────────────────────────
echo ""
echo "✅ Deployment complete!"
echo "   → app.js is ready to serve"
echo "   → frontend/dist/ is built and ready"
echo "   → Plesk will restart the Node.js app automatically"
echo ""
