PORT=5001
CLIENT_URL=https://meetconnect.swiftcampus.com

# ─── mediasoup SFU ───────────────────────────────────────────────────────────
# The IP address mediasoup announces to clients for WebRTC connections.
# LOCAL DEV: 127.0.0.1
# PRODUCTION: set to your server's public IP (e.g. 103.x.x.x)
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# ─── Self-Hosted coturn TURN Server ──────────────────────────────────────────
# GitHub: https://github.com/coturn/coturn
#
# Replace these values with your actual server details.
# See TURN Server/README.md for full setup instructions.

# ── LOCAL DEVELOPMENT (your machine / Linux VM) ───────────────────────────────
# Use 127.0.0.1 for same-machine testing
# Use your Linux VM's IP (e.g. 192.168.1.105) for LAN/VM testing
TURN_HOST=127.0.0.1

# TURN/STUN listening port (default: 3478)
TURN_PORT=3478

# TURN TLS port — disabled for local dev (no TLS cert locally)
TURN_TLS_PORT=

# Shared secret — MUST match static-auth-secret in turnserver-local.conf
# Local dev uses this fixed secret (change for production!)
TURN_SECRET=localdevelopmentsecret123

# Credential TTL in seconds (default: 86400 = 24 hours)
TURN_TTL=86400

# ── PRODUCTION (Hostinger VPS) — uncomment and fill in when deploying ─────────
# TURN_HOST=YOUR_VPS_PUBLIC_IP
# TURN_PORT=3478
# TURN_TLS_PORT=5349
# TURN_SECRET=YOUR_STRONG_RANDOM_SECRET_HERE
# TURN_TTL=86400
