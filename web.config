<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ─── iisnode handler: route app.js through iisnode ─────────────────── -->
    <handlers>
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- ─── URL Rewrite: send all requests to app.js (Node.js) ───────────── -->
    <rewrite>
      <rules>
        <!-- Do NOT rewrite iisnode internal requests -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^app.js\/debug[\/]?" />
        </rule>

        <!-- Route ALL requests to app.js (Express handles static + API + SPA) -->
        <rule name="NodeJS" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="app.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- ─── iisnode configuration ─────────────────────────────────────────── -->
    <iisnode
      loggingEnabled="true"
      devErrorsEnabled="true"
      logDirectory="iisnode"
      watchedFiles="web.config;*.js"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      gracefulShutdownTimeout="60000"
      debuggingEnabled="false"
    />

    <!-- ─── Disable IIS WebSocket module (conflicts with Socket.IO) ───────── -->
    <webSocket enabled="false" />

    <!-- ─── Security: allow larger request bodies ─────────────────────────── -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
